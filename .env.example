# ── Credenciales del panel admin ──────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu_contraseña_segura
JWT_SECRET=tu_secreto_jwt_super_largo_y_aleatorio_cambia_esto

# ── Vercel KV (Redis) ─────────────────────────────────────────────
# Estas variables las genera Vercel automáticamente cuando creas
# un KV Store y lo conectas a tu proyecto.
# Para desarrollo local, cópialas desde el panel de Vercel →
# Storage → tu KV Store → .env.local tab
KV_REST_API_URL=https://xxxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
KV_REST_API_READ_ONLY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
